{
  "manifest_version": 3,
  "name": "Assembly-TimeSharp",
  "short_name": "ATS",
  "version": "1.0.0",
  "description": "Assembly-TimeSharp is a Frame-Accurate Speedrun Retiming Tool for Youtube and Twitch, works on Speedrun.com.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "ATS.png",
        "assets/aller.regular.ttf",
        "assets/icons/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Assembly-TimeSharp (ATS)",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_popup": "src/popup.html"
  }
}
